# Stellar testnet keypair (generate with: node -e "const { Keypair } = require('@stellar/stellar-sdk'); const kp = Keypair.random(); console.log('PUBLIC=' + kp.publicKey()); console.log('SECRET=' + kp.secret())")
STELLAR_PUBLIC_KEY=
STELLAR_SECRET_KEY=

# Server
PORT=3001

# OZ Facilitator API key (get from https://channels.openzeppelin.com/testnet/gen)
FACILITATOR_API_KEY=
